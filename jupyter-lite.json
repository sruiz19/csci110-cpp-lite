{
  "jupyter-config-data": {
    "defaultDrive": "contents",
    "disabledExtensions": [],
    "settingsOverrides": {
      "@jupyterlab/apputils-extension:themes": {
        "theme": "JupyterLab Light"
      }
    },

    "workspaces": {
      "default": {
        "data": {
          "layout-restorer:data": {
            "main": {
              "dock": {
                "type": "split-area",
                "orientation": "horizontal",
                "sizes": [
                  1
                ],
                "children": [
                  {
                    "type": "tab-area",
                    "currentIndex": 0,
                    "widgets": [
                      "index.html"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
